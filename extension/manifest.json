{
  "manifest_version": 3,
  "name": "YouTube RAG Chatbot",
  "version": "1.0.0",
  "description": "Ask questions about the YouTube video you're currently watching.",
  "permissions": ["activeTab"],
  "host_permissions": [
    "https://www.youtube.com/*",
    "http://localhost:8000/*"
  ],
  "content_scripts": [
    {
      "matches": ["https://www.youtube.com/*"],
      "js": ["content.js"],
      "css": ["sidebar.css"],
      "run_at": "document_idle"
    }
  ]
}